PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL — app reads from this file. Copy from .env.example and set your password.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin@123
DB_DATABASE=Status_Tracking

# JWT (required for RBAC-protected routes like /api/admin/*)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
