PORT=3000
CLIENT_ORIGIN=http://localhost:5174

# JWT (optional). If set, login uses access + refresh tokens.
# JWT_SECRET=your-secret-key

# PostgreSQL — use either DATABASE_URL or DB_* below.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# If password contains @ or #, use DATABASE_URL and encode them (e.g. @ → %40).

DB_HOST=localhost
DB_PORT=5432
DB_USER=IT_Updates
DB_PASSWORD=admin@123
DB_DATABASE=It_updates
